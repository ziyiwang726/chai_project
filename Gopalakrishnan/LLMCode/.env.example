# Copy this file to .env and fill in the values for the providers you plan to use.
# .env is gitignored. Never commit real keys.
#
# ---------------------------------------------------------------------------
# 1) Pick ONE LLM provider (or set per-run with `export LLM_PROVIDER=...`).
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai          # openai | claude | gemini

# ---------------------------------------------------------------------------
# 2A) External users (no Cornell access): use the standard public APIs.
#     Leave OPENAI_BASE_URL / API_BASE_URI UNSET. The pipeline will then call
#     api.openai.com, api.anthropic.com, or generativelanguage.googleapis.com
#     directly via the official SDKs.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=                              # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=                           # https://console.anthropic.com/settings/keys
GEMINI_API_KEY=                              # https://aistudio.google.com/app/apikey

# Optional model overrides. If unset, sensible defaults from llm_provider_client.py are used.
# OPENAI_MODEL=gpt-5.4
# ANTHROPIC_MODEL=claude-opus-4-6
# GEMINI_MODEL=gemini-3.1-pro-preview

# ---------------------------------------------------------------------------
# 2B) Cornell users only: route everything through the LiteLLM proxy with one key.
#     Setting OPENAI_BASE_URL together with OPENAI_API_KEY (or CORNELL_API_KEY)
#     activates proxy mode automatically; in that case set LLM_MODEL with a
#     proxy-prefixed name like `openai.gpt-5.4`, `anthropic.claude-4.6-opus`, or
#     `google.gemini-3.1-pro-preview`.
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=https://api.ai.it.cornell.edu
# CORNELL_API_KEY=
# LLM_MODEL=openai.gpt-5.4

# ---------------------------------------------------------------------------
# 3) NCBI E-utilities (used by taxonomy + PubMed lookup stages).
#     NCBI_EMAIL is required by NCBI; NCBI_API_KEY is optional but raises rate limits.
# ---------------------------------------------------------------------------
NCBI_EMAIL=
NCBI_API_KEY=

# ---------------------------------------------------------------------------
# 4) Optional tuning knobs.
# ---------------------------------------------------------------------------
# LLM_REQUEST_TIMEOUT_SECONDS=300
# ANTHROPIC_MAX_TOKENS=4096
# GEMINI_MAX_OUTPUT_TOKENS=4096
